# ==================================
# OmniGov Environment Variables
# ==================================
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=omnigov
DB_USER=omnigov
DB_PASSWORD=omnigov_dev_password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# GVM / OpenVAS
GVM_ADMIN_PASSWORD=admin
GVM_ADMIN_USER=admin
GVM_HOST=localhost
GVM_PORT=9390
GVM_SOCKET_PATH=/run/gvmd/gvmd.sock
GVM_USE_MOCK=True

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=omnigov.noreply@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Site
SITE_DOMAIN=localhost:8000
SITE_NAME=OmniGov
