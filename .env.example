# ==================================
# OmniGov Environment Variables
# ==================================
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=omnigov
DB_USER=omnigov
DB_PASSWORD=omnigov_dev_password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# GVM / OpenVAS
GVM_ADMIN_PASSWORD=admin
GVM_ADMIN_USER=admin
GVM_HOST=localhost
GVM_PORT=9390
GVM_SOCKET_PATH=/run/gvmd/gvmd.sock
GVM_USE_MOCK=False

# Auth / OTP
# Keep this false locally. Turn it on only after SMTP is real and verified.
AUTH_REQUIRE_OTP=False

# Email delivery
# Use console locally. Switch to smtp before deployment.
EMAIL_DELIVERY_MODE=console

# Email (SMTP, for later deployment)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=omnigov.noreply@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=omnigov.noreply@gmail.com

# AI correlation enrichment (Claude via Anthropic API)
# Leave ANTHROPIC_API_KEY blank for deterministic local-only matching.
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
AI_CORRELATION_MODEL=claude-haiku-4-5
AI_CORRELATION_MAX_CANDIDATES=8
AI_CORRELATION_TOP_MATCHES=3

# Site
SITE_DOMAIN=localhost:8000
SITE_NAME=OmniGov
