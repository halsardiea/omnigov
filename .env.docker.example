# ==============================================================
# OmniGov — Docker Environment File
# ==============================================================
# Copy this file to .env and fill in the two required values.
#
#   cp .env.docker.example .env
#
# Then edit .env and set DJANGO_SECRET_KEY and ANTHROPIC_API_KEY.
# Everything else has safe defaults for local Docker use.
# ==============================================================

# ── REQUIRED: Change these two ──────────────────────────────

# Generate a random secret key, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Your Anthropic API key — get one at https://console.anthropic.com/settings/keys
# Without this, AI correlation still runs in heuristic-only mode (no Claude).
ANTHROPIC_API_KEY=

# ── Optional: keep the defaults unless you need to change them

# Database (matches the postgres service in docker-compose.yml)
DB_NAME=omnigov
DB_USER=omnigov
DB_PASSWORD=omnigov_secret

# GVM admin credentials (matches what you set when you run the first-run command)
GVM_ADMIN_USER=admin
GVM_ADMIN_PASSWORD=admin

# AI model
AI_CORRELATION_MODEL=claude-3-5-haiku-20241022
AI_CORRELATION_MAX_CANDIDATES=8
AI_CORRELATION_TOP_MATCHES=3

# Site display name
SITE_NAME=OmniGov
